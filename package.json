{
  "name": "gestao-processual",
  "version": "1.10.29",
  "description": "Sistema de gestão de processos e licitações",
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run client:dev\"",
    "server:dev": "ts-node server/index.ts",
    "server:start": "node server/dist/index.js",
    "client:dev": "cd client && npm run dev",
    "client:build": "cd client && npm run build",
    "build": "npm run client:build",
    "start": "node server/dist/index.js",
    "lint": "eslint .",
    "railway": "railway up"
  },
  "keywords": [
    "gestão",
    "processos",
    "licitação",
    "dashboard"
  ],
  "author": "Denilson",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/cookie-parser": "^1.4.9",
    "@types/express": "^5.0.3",
    "concurrently": "^8.2.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.3.0",
    "increase-memory-limit": "^1.0.7",
    "puppeteer": "^24.10.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.38.0"
  },
  "dependencies": {
    "cookie-parser": "^1.4.7",
    "csv-parse": "^5.6.0",
    "dotenv": "^16.5.0",
    "pg": "^8.16.1",
    "sharp": "^0.34.3"
  }
}